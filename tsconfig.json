{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */
    "target": "es2021",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node", "vitest"],
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "translations",
    "dist",
    "vitest.config.ts",
    "vitest.bin.config.ts"
  ]
}
